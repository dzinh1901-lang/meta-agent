{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TaskPacket",
  "type": "object",
  "required": [
    "task_id",
    "objective",
    "repository",
    "target_orchestrator",
    "risk_level",
    "requested_outputs",
    "validation_requirements",
    "audit_correlation_id"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "objective": {
      "type": "string"
    },
    "repository": {
      "type": "string"
    },
    "target_orchestrator": {
      "type": [
        "string",
        "null"
      ]
    },
    "risk_level": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "requested_outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation_requirements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requires_human_approval": {
      "type": "boolean"
    },
    "approval_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "audit_correlation_id": {
      "type": "string"
    }
  }
}