{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentRun",
  "type": "object",
  "required": [
    "run_id",
    "agent",
    "status",
    "input_summary",
    "outputs",
    "approval_ids",
    "audit_correlation_id",
    "created_at"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "agent": { "type": "string", "minLength": 1 },
    "status": { "enum": ["planned", "running", "paused_for_approval", "completed", "blocked", "failed"] },
    "input_summary": { "type": "string", "minLength": 1 },
    "outputs": { "type": "array" },
    "approval_ids": { "type": "array", "items": { "type": "string" } },
    "approval_decision_ids": { "type": "array", "items": { "type": "string" } },
    "audit_correlation_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
