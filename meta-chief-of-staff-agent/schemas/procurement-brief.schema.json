{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProcurementBrief",
  "type": "object",
  "required": [
    "procurement_brief_id",
    "procurement_request_id",
    "repository",
    "summary",
    "intent",
    "risk_level",
    "budget_band",
    "estimated_cost",
    "currency",
    "required_approver_roles",
    "blocked",
    "block_reasons",
    "missing_information",
    "vendor_risk_matrix",
    "recommendation",
    "autonomous_spend_allowed",
    "autonomous_vendor_award_allowed",
    "external_side_effect_executed"
  ],
  "properties": {
    "procurement_brief_id": { "type": "string" },
    "procurement_request_id": { "type": "string" },
    "repository": { "type": "string" },
    "summary": { "type": "string" },
    "intent": { "enum": ["research", "shortlist", "award", "contract", "payment"] },
    "risk_level": { "enum": ["low", "medium", "high", "critical"] },
    "budget_band": { "enum": ["not_provided", "standard", "major", "strategic"] },
    "estimated_cost": { "type": ["number", "null"] },
    "currency": { "type": "string" },
    "budget_owner": { "type": ["string", "null"] },
    "required_approver_roles": { "type": "array", "items": { "type": "string" } },
    "blocked": { "type": "boolean" },
    "block_reasons": { "type": "array", "items": { "type": "string" } },
    "missing_information": { "type": "array", "items": { "type": "string" } },
    "vendor_risk_matrix": { "type": "array", "items": { "type": "object" } },
    "recommendation": { "type": "string" },
    "autonomous_spend_allowed": { "const": false },
    "autonomous_vendor_award_allowed": { "const": false },
    "external_side_effect_executed": { "const": false }
  },
  "additionalProperties": false
}
