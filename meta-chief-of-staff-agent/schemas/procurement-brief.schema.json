{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProcurementBrief",
  "type": "object",
  "required": [
    "procurement_brief_id",
    "procurement_request_id",
    "repository",
    "summary",
    "intent",
    "risk_level",
    "budget_band",
    "estimated_cost",
    "currency",
    "selected_vendor_id",
    "required_approver_roles",
    "blocked",
    "block_reasons",
    "hard_block_reasons",
    "readiness_block_reasons",
    "missing_information",
    "vendor_risk_matrix",
    "recommendation",
    "approval_scope",
    "autonomous_spend_allowed",
    "autonomous_vendor_award_allowed",
    "external_side_effect_executed"
  ],
  "properties": {
    "procurement_brief_id": { "type": "string", "minLength": 1 },
    "procurement_request_id": { "type": "string", "minLength": 1 },
    "repository": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "intent": { "enum": ["research", "shortlist", "award", "contract", "payment"] },
    "risk_level": { "enum": ["low", "medium", "high", "critical"] },
    "budget_band": { "enum": ["not_provided", "standard", "major", "strategic"] },
    "estimated_cost": { "type": ["number", "null"], "minimum": 0 },
    "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
    "budget_owner": { "type": ["string", "null"] },
    "selected_vendor_id": { "type": ["string", "null"] },
    "required_approver_roles": { "type": "array", "items": { "type": "string" } },
    "blocked": { "type": "boolean" },
    "block_reasons": { "type": "array", "items": { "type": "string" } },
    "hard_block_reasons": { "type": "array", "items": { "type": "string" } },
    "readiness_block_reasons": { "type": "array", "items": { "type": "string" } },
    "missing_information": { "type": "array", "items": { "type": "string" } },
    "vendor_risk_matrix": { "type": "array", "items": { "type": "object" } },
    "recommendation": { "type": "string" },
    "approval_scope": {
      "type": "object",
      "required": ["repository", "action_type", "intent", "maximum_budget", "currency", "allowed_vendor_ids", "selected_vendor_id"],
      "properties": {
        "repository": { "type": "string" },
        "action_type": { "type": "string" },
        "intent": { "type": "string" },
        "maximum_budget": { "type": ["number", "null"] },
        "currency": { "type": "string" },
        "allowed_vendor_ids": { "type": "array", "items": { "type": "string" } },
        "selected_vendor_id": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "autonomous_spend_allowed": { "const": false },
    "autonomous_vendor_award_allowed": { "const": false },
    "external_side_effect_executed": { "const": false }
  },
  "additionalProperties": false
}
