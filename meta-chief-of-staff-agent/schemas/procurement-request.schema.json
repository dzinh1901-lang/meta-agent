{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProcurementRequest",
  "type": "object",
  "required": [
    "procurement_request_id",
    "repository",
    "summary",
    "intent",
    "category",
    "estimated_cost",
    "currency",
    "vendors",
    "selected_vendor_id",
    "contract_required",
    "data_access",
    "system_access",
    "sole_source",
    "cross_border",
    "regulated_domain",
    "administrative_review_only",
    "legal_compliance_review_id",
    "security_review_id",
    "contract_id",
    "purchase_order_id",
    "controlled_goods",
    "defense_related",
    "weapons_related",
    "evidence_refs"
  ],
  "properties": {
    "procurement_request_id": { "type": "string", "minLength": 1 },
    "repository": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "intent": { "enum": ["research", "shortlist", "award", "contract", "payment"] },
    "category": { "type": "string", "minLength": 1 },
    "estimated_cost": { "type": ["number", "null"], "minimum": 0 },
    "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
    "budget_owner": { "type": ["string", "null"] },
    "vendors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["vendor_id", "vendor_name"],
        "properties": {
          "vendor_id": { "type": "string", "minLength": 1 },
          "vendor_name": { "type": "string", "minLength": 1 },
          "data_access": { "type": "boolean" },
          "system_access": { "type": "boolean" },
          "security_review_status": { "type": "string" },
          "legal_review_status": { "type": "string" },
          "sole_source": { "type": "boolean" },
          "cross_border": { "type": "boolean" },
          "evidence_refs": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "selected_vendor_id": { "type": ["string", "null"] },
    "contract_required": { "type": "boolean" },
    "data_access": { "type": "boolean" },
    "system_access": { "type": "boolean" },
    "sole_source": { "type": "boolean" },
    "cross_border": { "type": "boolean" },
    "regulated_domain": { "type": "boolean" },
    "administrative_review_only": { "type": "boolean" },
    "legal_compliance_review_id": { "type": ["string", "null"] },
    "security_review_id": { "type": ["string", "null"] },
    "contract_id": { "type": ["string", "null"] },
    "purchase_order_id": { "type": ["string", "null"] },
    "controlled_goods": { "type": "boolean" },
    "defense_related": { "type": "boolean" },
    "weapons_related": { "type": "boolean" },
    "evidence_refs": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
